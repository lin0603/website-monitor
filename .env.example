# Website Monitor 環境變數設定
# 複製此檔案為 .env 並填入實際值

# 要監測的網站 URL，以逗號分隔（必填）
MONITOR_URLS=https://google.com,https://github.com

# Telegram Bot Token（必填）
# 透過 @BotFather 建立 Bot 取得
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID（必填）
# 可使用 @userinfobot 查詢自己的 Chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# 檢查間隔（秒），預設 60
CHECK_INTERVAL=60

# 請求超時時間（秒），預設 10
TIMEOUT=10
